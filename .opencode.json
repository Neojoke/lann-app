{
  "extensions": [
    "oh-my-opencode"
  ],
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "cloudflare": {
      "command": "npx",
      "args": ["-y", "@cloudflare/mcp-server"]
    }
  },
  "oh-my-opencode": {
    "enabled": true,
    "agents": {
      "default": {
        "model": "bailian/qwen3.5-plus",
        "description": "默认 Agent - 通用开发助手"
      },
      "architect": {
        "model": "bailian/qwen3.5-plus",
        "description": "架构师 - 系统设计和架构决策",
        "skills": ["system-design", "architecture-review"]
      },
      "coder": {
        "model": "bailian/qwen3.5-plus",
        "description": "开发者 - 代码编写和重构",
        "skills": ["coding", "refactoring", "debugging"]
      },
      "reviewer": {
        "model": "bailian/qwen3.5-plus",
        "description": "审查者 - 代码审查和质量检查",
        "skills": ["code-review", "security-audit"]
      },
      "tester": {
        "model": "bailian/qwen3.5-plus",
        "description": "测试工程师 - 测试用例和 E2E 测试",
        "skills": ["testing", "e2e", "maestro"]
      },
      "devops": {
        "model": "bailian/qwen3.5-plus",
        "description": "DevOps - 部署和基础设施",
        "skills": ["docker", "cloudflare", "ci-cd"]
      },
      "pm": {
        "model": "bailian/qwen3.5-plus",
        "description": "产品经理 - 需求分析和项目管理",
        "skills": ["project-management-skills", "adaptive-suite"]
      },
      "designer": {
        "model": "bailian/qwen3.5-plus",
        "description": "UI/UX 设计师 - 界面和体验设计",
        "skills": ["ui-ux-pro-max"]
      }
    },
    "workflows": {
      "feature": {
        "description": "新功能开发流程",
        "steps": [
          {"agent": "pm", "task": "需求分析"},
          {"agent": "designer", "task": "UI/UX 设计"},
          {"agent": "architect", "task": "技术方案"},
          {"agent": "coder", "task": "代码实现"},
          {"agent": "tester", "task": "测试验证"},
          {"agent": "reviewer", "task": "代码审查"}
        ]
      },
      "bugfix": {
        "description": "Bug 修复流程",
        "steps": [
          {"agent": "coder", "task": "问题定位"},
          {"agent": "coder", "task": "修复实现"},
          {"agent": "tester", "task": "回归测试"},
          {"agent": "reviewer", "task": "代码审查"}
        ]
      },
      "deploy": {
        "description": "部署流程",
        "steps": [
          {"agent": "devops", "task": "环境准备"},
          {"agent": "devops", "task": "构建部署"},
          {"agent": "tester", "task": "冒烟测试"},
          {"agent": "reviewer", "task": "验收确认"}
        ]
      }
    },
    "routing": {
      "auto": true,
      "rules": [
        {"pattern": "设计|UI|UX|界面", "agent": "designer"},
        {"pattern": "测试|E2E|Maestro", "agent": "tester"},
        {"pattern": "部署|Docker|Cloudflare|CI", "agent": "devops"},
        {"pattern": "需求|产品 | 项目", "agent": "pm"},
        {"pattern": "审查|review|audit", "agent": "reviewer"},
        {"pattern": "架构 | 设计模式 | 技术选型", "agent": "architect"},
        {"pattern": "编码 | 实现 | 修复", "agent": "coder"}
      ]
    }
  }
}
